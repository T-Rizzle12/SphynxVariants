<Defs>
	<!-- ==========================PlainSphynx============================ -->
	<ThingDef ParentName="AnimalThingBase">
		<defName>Base_Sphynx</defName>
		<label>Sphynx Cat</label>
		<description>Hairless and warm, the sphynx cat is a mutation of the usual cats found on the Rimworld through selective breeding. They make cozy and intelligent companions, as long as you keep them warm and fed of course.</description>
		<statBases>
			<MoveSpeed>4.4</MoveSpeed>
			<MarketValue>200</MarketValue>
			<ComfyTemperatureMin>18</ComfyTemperatureMin>
			<ComfyTemperatureMax>35</ComfyTemperatureMax>
			<Wildness>0</Wildness>
		</statBases>
		<race>
			<body>QuadrupedAnimalWithPawsAndTail</body>
			<soundEating>PredatorSmall_Eat</soundEating>
			<predator>true</predator>
			<useMeatFrom>Cat</useMeatFrom>
			<maxPreyBodySize>0.25</maxPreyBodySize>
			<baseBodySize>0.32</baseBodySize>
			<baseHungerRate>0.15</baseHungerRate>
			<baseHealthScale>0.42</baseHealthScale>
			<foodType>CarnivoreAnimal, OvivoreAnimal</foodType>
			<leatherDef>Leather_Light</leatherDef>
			<petness>1</petness>
			<specialTrainables>
				<li MayRequire="Ludeon.RimWorld.Odyssey">Comfort</li>
			</specialTrainables>
			<canCrossBreedWith>
				<li>Cat</li>
			</canCrossBreedWith>
			<trainability>Intermediate</trainability>
			<nuzzleMtbHours>12</nuzzleMtbHours>
			<gestationPeriodDays>10</gestationPeriodDays>
			<nameOnTameChance>1</nameOnTameChance>
			<litterSizeCurve>
				<points>
					<li>(0.5, 0)</li>
					<li>(1, 1)</li>
					<li>(2, 1.7)</li>
					<li>(3, 0.7)</li>
					<li>(3.5, 0)</li>
				</points>
			</litterSizeCurve>
			<lifeExpectancy>15</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.15</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.4</minAge>
					<soundWounded>Pawn_Cat_Injured</soundWounded>
					<soundDeath>Pawn_Cat_Death</soundDeath>
					<soundCall>Pawn_Cat_Call</soundCall>
					<soundAngry>Pawn_Cat_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
		</race>
		<tools>
			<li>
				<label>left claw</label>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>6</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>right claw</label>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>6</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>7</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
		<tradeTags>
			<li>AnimalUncommon</li>
			<li>AnimalPet</li>
		</tradeTags>
		<modExtensions>
			<li Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension">
				<crossBreedKindDef>Random</crossBreedKindDef>
			</li>
		</modExtensions>
	</ThingDef>
